# Copiez ce fichier en .env et adaptez. NE COMMITEZ PAS .env.

# --- Acces web (HTTP basic auth du bureau) ---
CUSTOM_USER=dofus
PASSWORD=change-me-strong-password

# --- Reverse proxy / TLS ---
# Domaine public (Let's Encrypt auto) ou nom LAN (+ "tls internal" dans Caddyfile).
DOMAIN=dofus.example.com

# --- Affichage ---
TITLE=Dofus
RES_W=1920
RES_H=1080
FRAMERATE=60

# --- Systeme ---
TZ=Europe/Paris
PUID=1000
PGID=1000

# --- GPU Intel/AMD (utilise seulement avec docker-compose.gpu-dri.yml) ---
# GID des groupes render/video de l'HOTE (getent group render video).
RENDER_GID=989
VIDEO_GID=44
# Noeud DRI si different de renderD128.
DRINODE=/dev/dri/renderD128
DRI_NODE=/dev/dri/renderD128
